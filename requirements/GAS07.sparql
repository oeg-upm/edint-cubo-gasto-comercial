# GAS07: ¿Cuál es el gasto comercial total por actividad económica y nacionalidad en una región y periodo concretos?

PREFIX edintgast: <http://vocab.linkeddata.es/datosabiertos/def/comercio/cubo-gasto-comercial/>
PREFIX qb: <http://purl.org/linked-data/cube#>
PREFIX edintdimension: <http://vocab.linkeddata.es/datosabiertos/def/dimension#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX edintmeasure: <http://vocab.linkeddata.es/datosabiertos/def/measure#>

SELECT ?activity ?activityLabel ?nationality ?nationalityLabel (SUM(?amount) AS ?totalExpenditure)
WHERE {
  ?obs a qb:Observation ;
       qb:dataSet edintgast: ;
       edintdimension:refAdminRegion ?region ;
       edintdimension:refPeriod ?period ;
       edintdimension:economicActivity ?activity ;
       edintdimension:nationality ?nationality ;
       edintmeasure:expenditureAmount ?amount .

  FILTER(?region = <URI_REGION>)
  FILTER(?period = <URI_PERIODO>)

  OPTIONAL { ?activity skos:prefLabel ?activityLabel . FILTER(LANG(?activityLabel) = "es") }
  OPTIONAL { ?nationality rdfs:label ?nationalityLabel . FILTER(LANG(?nationalityLabel) = "es") }
}
GROUP BY ?activity ?activityLabel ?nationality ?nationalityLabel
ORDER BY DESC(?totalExpenditure)